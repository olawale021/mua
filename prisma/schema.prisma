generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SephoraCache {
  id        String   @id // cache key (full API URL)
  data      Json // raw API response
  expiresAt DateTime // when this entry becomes stale
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}
